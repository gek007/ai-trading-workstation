# Required: OpenRouter API key for LLM chat functionality
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Set to "true" for deterministic mock LLM responses (testing)
# When enabled, the LLM will return predefined responses instead of calling OpenRouter
LLM_MOCK=false

# Optional: Massive (Polygon) API key; when set, backend uses Massive polling instead of simulator
# If not set or empty, the built-in simulator will be used (default)
# Get your API key from https://polygon.io/
MASSIVE_API_KEY=

# Optional: Seed for deterministic simulator price sequence (testing)
# When set, the market simulator will use this seed for random number generation
# This makes price movements reproducible across runs, useful for testing
MARKET_SIM_SEED=
