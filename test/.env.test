# Test Environment Variables for FinAlly E2E Tests

# Enable mock LLM mode for deterministic tests
LLM_MOCK=true

# Set seed for deterministic market simulator
MARKET_SIM_SEED=42

# Base URL for application (default: http://localhost:8000)
BASE_URL=http://localhost:8000

# Optional: Massive API key (if testing with real market data)
# MASSIVE_API_KEY=your-key-here
